{
  "name": "shopping-gui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "LOCAL CODE ONLY, do not push to NPM. LOCAL servers ONLY, do not push to AWS etc.  Will be pushed to github at end",
  "author": {
    "name": "O Beresford"
  },
  "scripts": {
    "start": "../build-tools/start.bash ",
    "stop": "../build-tools/start.bash -q",
    "build:app": "export NODE_ENV=production;../build-tools/build.bash",
    "build:fe": "export NODE_ENV=production;../build-tools/build.bash --fe",
    "build:be": "export NODE_ENV=production;../build-tools/build.bash --be",
    "test:fe": "export NODE_ENV=development;  ../build-tools/test.bash --fe;  echo 'Add more tests!!!'",
    "test:be": "export NODE_ENV=development; ../build-tools/test.bash --be;  echo 'Add more tests!!!'",
    "coverage": "node ./node_modules/.bin/vitest --typecheck --coverage",
    "lint": "../build-tools/lint.bash",
    "clean": "../build-tools/clean.bash",
    "storybook": "node ./node_modules/.bin/storybook dev -p 6006 --https --ssl-cert ./src/assets/cert.pem --ssl-key ./src/assets/private.key ; node ./node_modules/.bin/storybook dev -p 6006 -c ./.storybook-suspence/ --https --ssl-cert ./src/assets/cert.pem --ssl-key ./src/assets/private.key ",
    "build-storybook": "node ./node_modules/.bin/storybook build; node ./node_modules/.bin/storybook build -c ./.storybook-suspence/"
  },
  "main": "main.mjs",
