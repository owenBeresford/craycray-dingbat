import { Listable, AList, ListStruct } from './AList';
import { ListService } from './ListService';

let FAKE:ListService;

const FAKE1_FACTORY = function ():ListService {
  if (!FAKE) {
    FAKE = new ListService();

    if (FAKE.count() === 0) {
      let id = FAKE.create('list1');
      let cc = FAKE.get(id);
      if (cc !== null) {
        cc.import(['cat', 'smol dog', 'gerbil', 'field mouse', 'gekko', 'skink',
          'danger noodle', 'hissy danger noodle']);
        FAKE.store(cc, id);
      }

      id = FAKE.create('list2');
      cc = FAKE.get(id);
      if (cc) {
        cc.import(['cat', 'smol dog', 'gerbil', 'field mouse', 'gekko', 'skink',
          'danger noodle', 'hissy danger noodle']);
        FAKE.store(cc, id);
      }

      id = FAKE.create('list3');
      cc = FAKE.get(id);
      if (cc) {
        cc.import(['cat', 'smol dog', 'gerbil', 'field mouse', 'gekko', 'skink',
          'danger noodle', 'hissy danger noodle']);
        FAKE.store(cc, id);
      }

      id = FAKE.create('list4');
      cc = FAKE.get(id);
      if (cc) {
        cc.import(['cat', 'smol dog', 'gerbil', 'field mouse', 'gekko', 'skink',
          'danger noodle', 'hissy danger noodle']);
        FAKE.store(cc, id);
      }
    }
  }
  return FAKE;
};

export default FAKE1_FACTORY;
