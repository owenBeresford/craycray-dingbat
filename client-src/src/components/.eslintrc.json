{
"type":"json",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint", "eslint-plugin-vue"],
  "extends": [
    "plugin:@typescript-eslint/recommended",
    "plugin:vue/vue3-essential",
    "@vue/typescript/recommended",
    "@vue/prettier"
  ],
  "rules": { "strict": 1 },
  "env": {
    "browser": true,
    "node": true
  }
}
