{
  "name": "shopping-api",
  "version": "1.0.0",
  "description": "Very simple internal API, LAN ONLY\nI have stopped iterating spelling on SVR, its now all BE",
  "main": "../dist/api.es.mjs",
  "private": true,
  "type": "module",
  "scripts": {
    "#start:debug": "nest start --debug --watch",
    "start": "../build-tools/start.bash ",
    "stop": "../build-tools/start.bash -q",
    "build:be": "export NODE_ENV=production; ../build-tools/build.bash --be; ",
    "build:fe": "export NODE_ENV=production; ../build-tools/build.bash --fe; ",
    "build": "export NODE_ENV=production; ../build-tools/build.bash",
    "test:be": "export NODE_ENV=development; ../build-tools/test.bash --be",
    "test:fe": "export NODE_ENV=development; ../build-tools/test.bash --fe",
    "lint": "../build-tools/lint.bash",
    "coverage": "node ./node_modules/.bin/vitest --coverage",
    "#preinstall": "export cani=`which nvm`; if [ -n \"$cani\" ]; then nvm use; else; npm i -D nvm; nvm use; fi",
    "prebuild": "export cani=`which nvm`; if [ -n \"$cani\" ]; then nvm use; fi"
  },
  "keywords": [
    "shopping",
    "testing",
    "app"
  ],
  "author": "Owen Beresford",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/serve-static": "^5.0.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "es-arraybuffer-base64": "^1.1.2",
    "express": "^5.2.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/express": "^4.17.13",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "^5.23.0",
    "@typescript-eslint/parser": "^5.23.0",
    "@typescript-eslint/typescript-estree": "^6.2.1",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.0.18",
    "common-es": "^1.1.0",
    "eslint": "^8.46.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-storybook": "^10.3.1",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vue": "^8.6.0",
    "jsdoc": "^4.0.5",
    "prettier": "^3.8.3",
    "rollup-plugin-auto-external": "^2.0.0",
    "rollup-plugin-polyfill-node": "^0.9.0",
    "rollup-plugin-postprocess": "^1.0.2",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.31.2",
    "source-map-support": "^0.5.20",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vite-plugin-ts": "^1.3.2-1",
    "vitest": "^4.1.5"
  }
}
